APP_URL=https://opensource-demo.orangehrmlive.com/
BROWSER=chrome
HEADLESS=true
REPORT_DIR=./TestResults
RUN_NAME=local
DRIVER_STARTUP_RETRIES=2
EXPLICIT_WAIT_SECONDS=20

# Leave empty for local Chrome execution.
# Use http://localhost:4444/wd/hub when running tests from host against Docker Grid.
# Use http://selenium:4444/wd/hub when running tests inside docker compose.
SELENIUM_REMOTE_URL=

# Optional local troubleshooting overrides.
# CHROME_BINARY_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# CHROME_USER_DATA_DIR=C:\Temp\orangehrm-chrome-profile
